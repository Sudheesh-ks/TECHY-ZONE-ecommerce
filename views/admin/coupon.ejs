<%- include("../../views/partials/admin/header") %>
<section class="content-main">
    <div class="content-header">
        <div>
            <h2 class="content-title card-title">Manage Coupons</h2>
        </div>
        <div class="page-actions">
            <a href="/admin/addCoupon" class="btn btn-primary">Add Coupon</a>
        </div>
    </div>

    <div class="card card-body mb-4">
        <form action="/admin/coupons" method="get" class="mb-0">
            <div class="input-group" style="max-width: 560px;">
                <input type="text" class="form-control" placeholder="Search coupons..." name="search">
                <button class="btn btn-light" type="submit"><i class="material-icons md-search"></i></button>
            </div>
        </form>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Code</th>
                            <th scope="col">Discount</th>
                            <th scope="col">Min Amount</th>
                            <th scope="col">Max Discount</th>
                            <th scope="col">Users Used</th>
                            <th scope="col">Remaining</th>
                            <th scope="col">Expiry Date</th>
                            <th scope="col">Status</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% coupons.forEach(coupon => { %>
                            <tr>
                                <td><%= coupon.couponCode %></td>
                                <td><%= coupon.discount %>%</td>
                                <td>₹<%= coupon.minAmount %></td>
                                <td>₹<%= coupon.maxDiscount %></td>
                                <td><%= coupon.userUsed %></td>
                                <td><%= coupon.maxUsage %></td>
                                <td><%= coupon.expiryDate.toISOString().split('T')[0] %></td>
                                <td><%= coupon.isActive ? 'Active' : 'Inactive' %></td>
                                <td>
                                    <a href="/admin/editCoupon/<%= coupon._id %>" class="btn btn-primary btn-sm me-2">Edit</a>
                                    <button type="button" class="btn btn-danger btn-sm confirm-action" data-confirm-title="Delete coupon" data-confirm-text="This coupon will be permanently deleted. Continue?" data-url="/admin/delete-coupon/<%= coupon._id %>" data-method="DELETE" data-redirect="/admin/coupon">Delete</button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
<%- include("../../views/partials/admin/footer") %>
