<%- include("../../views/partials/admin/header") %>
<section class="content-main">
    <div class="content-header">
        <div>
            <h2 class="content-title card-title">Order Details</h2>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title mb-4">Items in Order</h5>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Image</th>
                                    <th>Product Name</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% order.products.forEach(item => { %>
                                    <% const unitPrice = typeof item.price === 'number' ? item.price : (item.productDetails?.offerPrice || item.productDetails?.price || 0); %>
                                    <tr>
                                        <td>
                                            <img src="<%= item.productDetails.images %>" alt="<%= item.productDetails.name %>" class="rounded" style="width: 48px; height: 48px; object-fit: cover;">
                                        </td>
                                        <td><%= item.productDetails.name %></td>
                                        <td>₹<%= Number(unitPrice).toFixed(2) %></td>
                                        <td><%= item.quantity %></td>
                                        <td>₹<%= (item.quantity * Number(unitPrice)).toFixed(2) %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title mb-3">Shipping Address</h5>
                    <div class="mb-2"><strong>Name:</strong> <%= order.address.name %></div>
                    <div class="mb-2"><strong>City:</strong> <%= order.address.city %></div>
                    <div class="mb-2"><strong>Landmark:</strong> <%= order.address.landMark %></div>
                    <div class="mb-2"><strong>State:</strong> <%= order.address.state %></div>
                    <div class="mb-2"><strong>Pin Code:</strong> <%= order.address.pincode %></div>
                    <div class="mb-2"><strong>Phone:</strong> <%= order.address.phone %></div>
                    <div><strong>Alternate Phone:</strong> <%= order.address.altPhone || 'N/A' %></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form action="/admin/update-order-status/<%= order._id %>" method="POST" class="row g-3 align-items-end confirm-action" data-confirm-title="Update order status" data-confirm-text="Are you sure you want to update the order status?">
                <div class="col-md-6">
                    <label class="form-label" for="status">Order Status</label>
                    <select id="status" name="status" class="form-select" <%= (order.status === 'Cancelled' || order.status === 'Delivered' || order.status === 'Returned') ? 'disabled' : '' %>>
                        <option value="Processing" <%= order.status === 'Processing' ? 'selected' : '' %>>Processing</option>
                        <option value="Shipped" <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                        <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                        <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <button type="submit" class="btn btn-primary w-100" <%= (order.status === 'Cancelled' || order.status === 'Delivered' || order.status === 'Returned') ? 'disabled' : '' %>>Update Status</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Order Details</h5>
            <div class="mb-2"><strong>Status:</strong> <%= order.status %></div>
            <div><strong>Reason for Cancellation:</strong> <%= order.cancelReason || 'No reason provided' %></div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Return Status</h5>
            <% if (order.returnStatus === 'Requested') { %>
                <div class="mb-3"><strong>Reason for Return:</strong> <%= order.returnReason || 'No reason provided' %></div>
                <div class="d-flex gap-2">
                    <form action="/admin/approve-return/<%= order._id %>" method="POST" class="confirm-action" data-confirm-title="Approve return" data-confirm-text="Approve the customer's return request?">
                        <button class="btn btn-success" type="submit">Approve</button>
                    </form>
                    <form action="/admin/reject-return/<%= order._id %>" method="POST" class="confirm-action" data-confirm-title="Reject return" data-confirm-text="Reject the customer's return request?">
                        <button class="btn btn-danger" type="submit">Reject</button>
                    </form>
                </div>
            <% } else { %>
                <div><strong>Status:</strong> <%= order.returnStatus || 'N/A' %></div>
            <% } %>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Product Return Status</h5>
            <% order.products.forEach(product => { %>
                <div class="mb-4 border-bottom pb-3">
                    <div class="mb-2"><strong><%= product.name %></strong></div>
                    <div class="mb-2"><strong>Status:</strong> <%= product.returnStatus || 'N/A' %></div>
                    <% if (product.returnStatus === 'Requested') { %>
                        <div class="mb-3"><strong>Reason for Return:</strong> <%= product.returnReason || 'No reason provided' %></div>
                        <div class="d-flex gap-2">
                            <form action="/admin/approve-return/<%= order._id %>/<%= product.productId %>" method="POST" class="confirm-action" data-confirm-title="Approve item return" data-confirm-text="Approve return for this item?">
                                <button class="btn btn-success" type="submit">Approve</button>
                            </form>
                            <form action="/admin/reject-return/<%= order._id %>/<%= product.productId %>" method="POST" class="confirm-action" data-confirm-title="Reject item return" data-confirm-text="Reject return for this item?">
                                <button class="btn btn-danger" type="submit">Reject</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        </div>
    </div>
</section>

<%- include("../../views/partials/admin/footer") %>
