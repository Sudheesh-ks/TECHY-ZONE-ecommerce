<%- include("../../views/partials/admin/header") %>
<section class="content-main">
    <div class="content-header">
        <div>
            <h2 class="content-title card-title">Add New Product</h2>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form action="/admin/products/add" method="post" class="forms-sample row g-4" id="productForm" enctype="multipart/form-data" novalidate>
                <div class="col-12">
                    <label for="productName" class="form-label">Name</label>
                    <input type="text" class="form-control" id="productName" name="name" placeholder="Product Name" required />
                    <p class="error-message" id="productNameError"></p>
                </div>

                <div class="col-12">
                    <label class="form-label">Images <span class="text-danger">*</span> <small class="text-muted">(All 3 images required)</small></label>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <input type="file" class="form-control" id="productImage1" name="productImage1" accept="image/png, image/gif, image/jpeg" onchange="previewAndCrop(event, 0)" />
                            <div class="cropPreviewSection mt-2" id="cropPreviewSection0" style="display: none;">
                                <img id="cropPreview0" class="rounded" />
                                <button type="button" class="btn btn-primary btn-sm mt-2" onclick="startCropping(0)"><i class="fas fa-crop"></i> Crop Image 1</button>
                            </div>
                            <div id="croppedImagePreview0" class="cropped-image-preview mt-2"></div>
                        </div>
                        <div class="col-md-4">
                            <input type="file" class="form-control" id="productImage2" name="productImage2" accept="image/*" onchange="previewAndCrop(event, 1)" />
                            <div class="cropPreviewSection mt-2" id="cropPreviewSection1" style="display: none;">
                                <img id="cropPreview1" class="rounded" />
                                <button type="button" class="btn btn-primary btn-sm mt-2" onclick="startCropping(1)"><i class="fas fa-crop"></i> Crop Image 2</button>
                            </div>
                            <div id="croppedImagePreview1" class="cropped-image-preview mt-2"></div>
                        </div>
                        <div class="col-md-4">
                            <input type="file" class="form-control" id="productImage3" name="productImage3" accept="image/*" onchange="previewAndCrop(event, 2)" />
                            <div class="cropPreviewSection mt-2" id="cropPreviewSection2" style="display: none;">
                                <img id="cropPreview2" class="rounded" />
                                <button type="button" class="btn btn-primary btn-sm mt-2" onclick="startCropping(2)"><i class="fas fa-crop"></i> Crop Image 3</button>
                            </div>
                            <div id="croppedImagePreview2" class="cropped-image-preview mt-2"></div>
                        </div>
                    </div>
                    <p class="error-message" id="imageError"></p>
                </div>

                <div class="col-md-6">
                    <label for="productDescription" class="form-label">Description</label>
                    <input type="text" class="form-control" id="productDescription" name="description" placeholder="Product Description" required />
                    <p class="error-message" id="descError"></p>
                </div>

                <div class="col-md-6">
                    <label for="productCategory" class="form-label">Category</label>
                    <select class="form-select" id="productCategory" name="category" required>
                        <option value="" disabled selected>Select a Category</option>
                        <% for (let i = 0; i < cat.length; i++) { %>
                            <option value="<%= cat[i]._id %>"><%= cat[i].name %></option>
                        <% } %>
                    </select>
                    <p class="error-message" id="categoryError"></p>
                </div>

                <div class="col-md-4">
                    <label for="productOgPrice" class="form-label">Price</label>
                        <input type="number" class="form-control" id="productOgPrice" name="price" placeholder="Original Price" min="1" required />
                        <p class="error-message" id="ogPriceError"></p>
                    </div>
                    <div class="col-md-4">
                        <label for="productOfferPrice" class="form-label">Offer Price</label>
                        <input type="number" class="form-control" id="productOfferPrice" name="offerPrice" placeholder="Offer Price" min="1" required />
                        <p class="error-message" id="offerPriceError"></p>
                    </div>
                    <div class="col-md-4">
                        <label for="productStock" class="form-label">Stock</label>
                        <input type="number" class="form-control" id="productStock" name="stock" placeholder="Stock" min="1" required />
                    </div>

                <div class="col-12">
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="toggleWarranty" onclick="toggleWarrantyInput()" />
                        <label class="form-check-label" for="toggleWarranty">Add Warranty</label>
                    </div>
                    <div class="warranty-input mt-3" id="warrantyDiv" style="display: none;">
                        <label for="productWarranty" class="form-label">Warranty</label>
                        <input type="text" class="form-control" id="productWarranty" name="warranty" placeholder="Warranty" />
                        <p class="error-message" id="warrantyError"></p>
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="toggleReturnPolicy" onclick="toggleReturnPolicyInput()" />
                        <label class="form-check-label" for="toggleReturnPolicy">Add Return Policy</label>
                    </div>
                    <div class="return-policy-input mt-3" id="returnPolicyDiv" style="display: none;">
                        <label for="productReturnPolicy" class="form-label">Return Policy</label>
                        <input type="text" class="form-control" id="productReturnPolicy" name="returnPolicy" placeholder="Return Policy" />
                        <p class="error-message" id="returnPolicyError"></p>
                    </div>
                </div>

                <div class="col-12">
                    <button type="submit" id="productSubmitBtn" class="btn btn-primary btn-CreateProduct">
                        <span class="btn-text">Create Product</span>
                        <span class="btn-spinner spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true" style="display:none"></span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.12/dist/cropper.min.js"></script>
<script src="/admin/js/validate.js"></script>
<%- include("../../views/partials/admin/footer") %>



