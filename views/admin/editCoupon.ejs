<%- include("../../views/partials/admin/header") %>
<section class="content-main">
    <div class="content-header">
        <div>
            <h2 class="content-title card-title">Edit Coupon</h2>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form id="editCouponForm" class="row g-4">
                <div class="col-md-6">
                    <label for="couponCode" class="form-label">Coupon Code (Unique)</label>
                    <input type="text" name="couponCode" class="form-control" id="couponCode" value="<%= coupon.couponCode %>" placeholder="Coupon Code" required />
                </div>
                <div class="col-md-6">
                    <label for="discount" class="form-label">Discount (%)</label>
                    <input type="number" name="discount" class="form-control" id="discount" value="<%= coupon.discount %>" placeholder="Discount %" min="1" max="100" required />
                </div>
                <div class="col-md-6">
                    <label for="minAmount" class="form-label">Minimum Amount</label>
                    <input type="number" name="minAmount" class="form-control" id="minAmount" value="<%= coupon.minAmount %>" placeholder="Minimum Amount" min="1" required />
                </div>
                <div class="col-md-6">
                    <label for="maxDiscount" class="form-label">Maximum Discount</label>
                    <input type="number" name="maxDiscount" class="form-control" id="maxDiscount" value="<%= coupon.maxDiscount %>" placeholder="Maximum Discount" min="1" required />
                </div>
                <div class="col-md-6">
                    <label for="expiryDate" class="form-label">Expiry Date</label>
                    <% const formattedDate = coupon.expiryDate ? coupon.expiryDate.toISOString().split('T')[0] : ''; %>
                    <input type="date" name="expiryDate" class="form-control" id="expiryDate" value="<%= formattedDate %>" required />
                </div>
                <div class="col-md-6">
                    <label for="maxUsage" class="form-label">Max Usage</label>
                    <input type="number" name="maxUsage" class="form-control" id="maxUsage" value="<%= coupon.maxUsage %>" placeholder="Max Usage" min="1" required />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Update Coupon</button>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const expiryInput = document.getElementById('expiryDate');
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        expiryInput.setAttribute('min', tomorrow.toISOString().split('T')[0]);

        document.getElementById('editCouponForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const couponCode = document.getElementById('couponCode').value.trim();
            const discount = document.getElementById('discount').value;
            const minAmount = document.getElementById('minAmount').value;
            const maxDiscount = document.getElementById('maxDiscount').value;
            const expiryDate = document.getElementById('expiryDate').value;
            const maxUsage = document.getElementById('maxUsage').value;

            if (!couponCode || !discount || !minAmount || !maxDiscount || !expiryDate || !maxUsage) {
                return Swal.fire({ icon: 'error', title: 'Validation Error', text: 'All fields are required.' });
            }

            const discountValue = Number(discount);
            const minAmountValue = Number(minAmount);
            const maxDiscountValue = Number(maxDiscount);
            const maxUsageValue = Number(maxUsage);

            if (!Number.isFinite(discountValue) || discountValue < 1 || discountValue > 90) {
                return Swal.fire({ icon: 'error', title: 'Validation Error', text: 'Discount must be between 1% and 90%.' });
            }

            if (!Number.isFinite(minAmountValue) || minAmountValue < 100) {
                return Swal.fire({ icon: 'error', title: 'Validation Error', text: 'Minimum amount must be at least ₹100.' });
            }

            if (!Number.isFinite(maxDiscountValue) || maxDiscountValue < 50) {
                return Swal.fire({ icon: 'error', title: 'Validation Error', text: 'Maximum discount must be at least ₹50.' });
            }

            if (!Number.isFinite(maxUsageValue) || maxUsageValue < 1) {
                return Swal.fire({ icon: 'error', title: 'Validation Error', text: 'Maximum usage must be at least 1.' });
            }

            if (maxDiscountValue > minAmountValue) {
                return Swal.fire({ icon: 'error', title: 'Validation Error', text: 'The maximum discount cap must not be higher than the minimum order value for this coupon.' });
            }

            const selectedDate = new Date(expiryDate);
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            if (selectedDate <= today) {
                return Swal.fire({ icon: 'error', title: 'Validation Error', text: 'Expiry date must be a future date.' });
            }

            const formData = new FormData(this);
            const response = await fetch('/admin/edit-coupon/<%= coupon._id %>', {
                method: 'PUT',
                body: JSON.stringify(Object.fromEntries(formData)),
                headers: { 'Content-Type': 'application/json' },
            });
            const data = await response.json();
            if (response.ok) {
                Swal.fire({ icon: 'success', title: 'Success', text: data.message }).then(() => {
                    window.location.href = '/admin/coupon';
                });
            } else {
                Swal.fire({ icon: 'error', title: 'Error', text: data.error || 'Failed to update coupon' });
            }
        });
    });
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>
<%- include("../../views/partials/admin/footer") %>
